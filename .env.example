# Copy this file to .env and fill values.

# Required Telegram settings
BOT_TOKEN=your_telegram_bot_token
ADMIN_ID=123456789
# CHANNEL_ID must be @channel_username or numeric Telegram chat/channel id.
# Do NOT use invite links like https://t.me/+...
CHANNEL_ID=@your_channel_username

# AI provider keys (OpenRouter is preferred if set)
OPENROUTER_API_KEY=optional_openrouter_api_key
OPENAI_API_KEY=optional_openai_api_key_fallback

# Models
MODEL_DRAFT=moonshotai/kimi-k2.6
MODEL_POLISH=anthropic/claude-sonnet-4.5

# Optional OpenRouter attribution headers
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=Simplify AI Autopilot

# Scheduler / storage
SCHEDULE_TIMEZONE=Europe/Moscow
DB_PATH=data/drafts.db

# Post length limits
POST_MAX_CHARS=1400
POST_SOFT_CHARS=1100

# Daily schedule slots, format: HH:MM,HH:MM,HH:MM
DAILY_POST_SLOTS=10:00,14:00,18:00,21:00

# Cost tracking (per 1M tokens)
OPENROUTER_INPUT_COST_PER_1M=0
OPENROUTER_OUTPUT_COST_PER_1M=0
OPENAI_INPUT_COST_PER_1M=0
OPENAI_OUTPUT_COST_PER_1M=0

# CUSTOM_EMOJI_MAP format: fallback_emoji|custom_emoji_id;...
CUSTOM_EMOJI_MAP=

# CUSTOM_EMOJI_ALIASES format: alias|fallback_emoji|custom_emoji_id;...
CUSTOM_EMOJI_ALIASES=

# CUSTOM_TOPIC_FEEDS format: name|group|url,name|group|url
CUSTOM_TOPIC_FEEDS=

# MAX_TOPIC_AGE_DAYS controls freshness filter for RSS topics (1..60 days).
MAX_TOPIC_AGE_DAYS=14
