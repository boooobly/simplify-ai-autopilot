# Copy this file to .env and fill values
BOT_TOKEN=your_telegram_bot_token
ADMIN_ID=123456789
CHANNEL_ID=@your_channel_username_or_id

# AI provider keys (OpenRouter is preferred if set)
OPENROUTER_API_KEY=optional_openrouter_api_key
OPENAI_API_KEY=optional_openai_api_key_fallback

# Models
MODEL_DRAFT=moonshotai/kimi-k2.6
MODEL_POLISH=anthropic/claude-sonnet-4.5

# Optional OpenRouter attribution headers
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=Simplify AI Autopilot

SCHEDULE_TIMEZONE=Europe/Moscow
DB_PATH=data/drafts.db

# Post length limits
POST_MAX_CHARS=1400
POST_SOFT_CHARS=1100
